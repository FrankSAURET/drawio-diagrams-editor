{
	"name": "vscode-drawio",
	"private": true,
	"displayName": "%displayName%",
	"description": "%description%",
	"version": "1.9.1",
	"preRelease": false,
	"license": "GPL-3.0",
	"publisher": "FrankSAURET",
	"keywords": [
		"drawio",
		"diagram",
		"diagrams.net",
		"visio",
		"architecture",
		"uml",
		"code link"
	],
	"author": {
		"name": "Frank Sauret",
		"url": "https://github.com/FrankSAURET"
	},
	"readme": "./README.md",
	"icon": "docs/logo.drawio.png",
	"extensionKind": [
		"ui",
		"workspace"
	],
	"engines": {
		"vscode": "^1.70.0"
	},
	"categories": [
		"Visualization"
	],
	"activationEvents": [],
	"repository": {
		"url": "https://github.com/FrankSAURET/vscode-drawio.git"
	},
	"browser": "./dist/extension/index",
	"main": "./dist/extension/index",
	"capabilities": {
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "drawio-explorer",
					"title": "%viewsContainers.activitybar.drawio-explorer.title%",
					"icon": "media/drawio-activity-bar.svg"
				}
			]
		},
		"views": {
			"drawio-explorer": [
				{
					"id": "drawio-welcome",
					"name": "%views.drawio-explorer.drawio-welcome.name%",
					"visibility": "visible",
					"initialSize": 1
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "drawio-welcome",
				"contents": "%viewsWelcome.drawio-welcome.contents%"
			}
		],
		"languages": [
			{
				"id": "drawio",
				"extensions": [
					".drawio",
					".dio",
					".dio.svg",
					".drawio.svg",
					".drawio.png",
					".dio.png"
				],
				"aliases": [
					"Draw.io",
					"drawio"
				]
			}
		],
		"customEditors": [
			{
				"viewType": "FrankSAURET.vscode-drawio",
				"displayName": "%customEditors.drawio.displayName%",
				"selector": [
					{
						"filenamePattern": "*.drawio.png"
					},
					{
						"filenamePattern": "*.dio.png"
					}
				],
				"priority": "default"
			},
			{
				"viewType": "FrankSAURET.vscode-drawio-text",
				"displayName": "%customEditors.drawio-text.displayName%",
				"selector": [
					{
						"filenamePattern": "*.drawio"
					},
					{
						"filenamePattern": "*.dio"
					},
					{
						"filenamePattern": "*.dio.svg"
					},
					{
						"filenamePattern": "*.drawio.svg"
					}
				],
				"priority": "default"
			}
		],
		"commands": [
			{
				"command": "FrankSAURET.vscode-drawio.convert",
				"title": "%commands.convert.title%",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.export",
				"title": "%commands.export.title%",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.toggleCodeLinkActivation",
				"title": "%commands.toggleCodeLinkActivation.title%",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.changeTheme",
				"title": "%commands.changeTheme.title%",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.editDiagramAsText",
				"title": "%commands.editDiagramAsText.title%",
				"enablement": "FrankSAURET.vscode-drawio.experimentalFeaturesEnabled",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.linkCodeWithSelectedNode",
				"title": "%commands.linkCodeWithSelectedNode.title%",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.newDiagram",
				"title": "%commands.newDiagram.title%",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.openDiagram",
				"title": "%commands.openDiagram.title%",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.linkFileWithSelectedNode",
				"title": "%commands.linkFileWithSelectedNode.title%",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.linkSymbolWithSelectedNode",
				"title": "%commands.linkSymbolWithSelectedNode.title%",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.linkWsSymbolWithSelectedNode",
				"title": "%commands.linkWsSymbolWithSelectedNode.title%",
				"category": "Draw.io"
			},
			{
				"command": "FrankSAURET.vscode-drawio.openAsText",
				"title": "%commands.openAsText.title%",
				"category": "Draw.io",
				"icon": "$(go-to-file)"
			},
			{
				"command": "FrankSAURET.vscode-drawio.openAsDiagram",
				"title": "%commands.openAsDiagram.title%",
				"category": "Draw.io",
				"icon": "$(preview)"
			}
		],
		"keybindings": [
			{
				"command": "FrankSAURET.vscode-drawio.linkCodeWithSelectedNode",
				"key": "shift+F3",
				"when": "!findWidgetVisible"
			}
		],
		"configuration": [
			{
				"title": "%configuration.general.title%",
				"order": 10,
				"properties": {
					"FrankSAURET.vscode-drawio.offline": {
						"type": "boolean",
						"default": true,
						"title": "%configuration.offline.title%",
						"description": "%configuration.offline.description%",
						"order": 10
					},
					"FrankSAURET.vscode-drawio.online-url": {
						"type": "string",
						"default": "https://embed.diagrams.net/",
						"title": "%configuration.online-url.title%",
						"description": "%configuration.online-url.description%",
						"order": 11
					},
					"FrankSAURET.vscode-drawio.codeLinkActivated": {
						"type": "boolean",
						"default": false,
						"title": "%configuration.codeLinkActivated.title%",
						"description": "%configuration.codeLinkActivated.description%",
						"order": 20
					},
					"FrankSAURET.vscode-drawio.local-storage": {
						"anyOf": [
							{
								"type": "object"
							},
							{
								"type": "string"
							}
						],
						"default": {},
						"readOnly": true,
						"title": "%configuration.local-storage.title%",
						"description": "%configuration.local-storage.description%",
						"order": 30
					},
					"FrankSAURET.vscode-drawio.simpleLabels": {
						"type": "boolean",
						"default": false,
						"title": "%configuration.simpleLabels.title%",
						"description": "%configuration.simpleLabels.description%",
						"order": 40
					},
					"FrankSAURET.vscode-drawio.zoomFactor": {
						"type": "number",
						"default": 1.2,
						"title": "%configuration.zoomFactor.title%",
						"description": "%configuration.zoomFactor.description%",
						"order": 50
					},
					"FrankSAURET.vscode-drawio.globalVars": {
						"type": "object",
						"title": "%configuration.globalVars.title%",
						"description": "%configuration.globalVars.description%",
						"order": 60
					},
					"FrankSAURET.vscode-drawio.resizeImages": {
						"type": [
							"boolean",
							"null"
						],
						"title": "%configuration.resizeImages.title%",
						"description": "%configuration.resizeImages.description%",
						"default": null,
						"order": 70
					}
				}
			},
			{
				"title": "%configuration.plugins.section.title%",
				"order": 20,
				"properties": {
					"FrankSAURET.vscode-drawio.plugins": {
						"type": "array",
						"items": {
							"anyOf": [
								{
									"type": "object",
									"properties": {
										"file": {
											"type": "string",
											"description": "The file path to the library. Must be absolute. You can use `${workspaceFolder}`."
										}
									}
								}
							]
						},
						"default": [],
						"title": "%configuration.plugins.title%",
						"markdownDescription": "%configuration.plugins.description%",
						"order": 10
					},
					"FrankSAURET.vscode-drawio.knownPlugins": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"pluginId": {
									"type": "string"
								},
								"fingerprint": {
									"type": "string"
								},
								"allowed": {
									"type": "boolean"
								}
							}
						},
						"default": [],
						"title": "%configuration.knownPlugins.title%",
						"markdownDescription": "%configuration.knownPlugins.description%",
						"scope": "application",
						"order": 15
					},
					"FrankSAURET.vscode-drawio.customLibraries": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"entryId": {
									"type": "string",
									"description": "The id of the entry. A specfic entry can be enabled or deactivated in the editor."
								},
								"libName": {
									"type": "string",
									"description": "The name of the library in the shape overview."
								}
							},
							"anyOf": [
								{
									"type": "object",
									"properties": {
										"url": {
											"type": "string"
										}
									}
								},
								{
									"type": "object",
									"properties": {
										"xml": {
											"type": "string"
										}
									}
								},
								{
									"type": "object",
									"properties": {
										"json": {}
									}
								},
								{
									"type": "object",
									"properties": {
										"file": {
											"type": "string",
											"description": "The file path to the library. Must be absolute. You can use ${workspaceFolder}."
										}
									}
								}
							]
						},
						"default": [],
						"title": "%configuration.customLibraries.title%",
						"description": "%configuration.customLibraries.description%",
						"order": 50
					}
				}
			},
			{
				"title": "%configuration.themeAndStyles.title%",
				"order": 30,
				"properties": {
					"FrankSAURET.vscode-drawio.styles": {
						"title": "%configuration.styles.title%",
						"description": "%configuration.styles.description%",
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"commonStyle": {
									"type": "object",
									"properties": {
										"fontColor": {
											"type": "string"
										},
										"strokeColor": {
											"type": "string"
										},
										"fillColor": {
											"type": "string"
										}
									}
								},
								"graph": {
									"type": "object",
									"properties": {
										"background": {
											"type": "string"
										},
										"gridColor": {
											"type": "string"
										}
									}
								}
							}
						}
					},
					"FrankSAURET.vscode-drawio.defaultVertexStyle": {
						"title": "%configuration.defaultVertexStyle.title%",
						"description": "%configuration.defaultVertexStyle.description%",
						"type": "object"
					},
					"FrankSAURET.vscode-drawio.defaultEdgeStyle": {
						"title": "%configuration.defaultEdgeStyle.title%",
						"description": "%configuration.defaultEdgeStyle.description%",
						"type": "object"
					},
					"FrankSAURET.vscode-drawio.colorNames": {
						"title": "%configuration.colorNames.title%",
						"description": "%configuration.colorNames.description%",
						"type": "object"
					},
					"FrankSAURET.vscode-drawio.presetColors": {
						"title": "%configuration.presetColors.title%",
						"description": "%configuration.presetColors.description%",
						"type": "array",
						"items": {
							"type": "string",
							"description": "Use hex codes without # at the beginning only (FFFFFF for absolute white, for example)."
						}
					},
					"FrankSAURET.vscode-drawio.customColorSchemes": {
						"title": "%configuration.customColorSchemes.title%",
						"markdownDescription": "%configuration.customColorSchemes.description%",
						"type": "array",
						"items": {
							"type": "array",
							"description": "Represents a page of color schemes.",
							"items": {
								"type": "object",
								"properties": {
									"title": {
										"type": "string",
										"description": "Title of the color used in tooltips."
									},
									"fill": {
										"type": "string",
										"description": "Use hex codes with # at the beginning (#FFFFFF for absolute white, for example)."
									},
									"stroke": {
										"type": "string",
										"description": "Use hex codes with # at the beginning (#FFFFFF for absolute white, for example)."
									},
									"gradient": {
										"type": "string",
										"description": "Use hex codes with # at the beginning (#FFFFFF for absolute white, for example)."
									},
									"font": {
										"type": "string",
										"description": "Use hex codes with # at the beginning (#FFFFFF for absolute white, for example)."
									}
								}
							}
						}
					},
					"FrankSAURET.vscode-drawio.customFonts": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"default": [],
						"title": "%configuration.customFonts.title%",
						"description": "%configuration.customFonts.description%"
					},
					"FrankSAURET.vscode-drawio.theme": {
						"title": "%configuration.theme.title%",
						"type": "string",
						"default": "kennedy",
						"enum": [
							"kennedy",
							"min"
						],
						"description": "%configuration.theme.description%"
					},
					"FrankSAURET.vscode-drawio.appearance": {
						"title": "%configuration.appearance.title%",
						"type": "string",
						"default": "light",
						"enum": [
							"automatic",
							"light",
							"dark",
							"high-contrast-light",
							"high-contrast"
						],
						"description": "%configuration.appearance.description%"
					}
				}
			}
		],
		"menus": {
			"explorer/context": [
				{
					"when": "FrankSAURET.vscode-drawio.active",
					"command": "FrankSAURET.vscode-drawio.linkFileWithSelectedNode",
					"group": "Draw.io"
				}
			],
			"commandPalette": [
				{
					"when": "false",
					"command": "FrankSAURET.vscode-drawio.linkFileWithSelectedNode"
				}
			],
			"editor/title": [
				{
					"command": "FrankSAURET.vscode-drawio.openAsText",
					"when": "activeCustomEditorId == 'FrankSAURET.vscode-drawio-text' || activeCustomEditorId == 'FrankSAURET.vscode-drawio'",
					"group": "navigation"
				},
				{
					"command": "FrankSAURET.vscode-drawio.openAsDiagram",
					"when": "!activeCustomEditorId && resourceFilename =~ /\\.(drawio|dio)(\\.svg|\\.png)?$/",
					"group": "navigation"
				}
			]
		}
	},
	"scripts": {
		"run-script": "node ./scripts/run-script",
		"lint": "echo 'add linting'",
		"_lint": "yarn run-script check-version && prettier --check ./src",
		"build": "yarn build-extension && yarn build-plugins && yarn package-extension",
		"build-extension": "webpack --mode production",
		"build-plugins": "webpack --mode production --config ./drawio-custom-plugins/webpack.config.ts",
		"package-extension": "yarn package-extension-preRelease",
		"package-extension-stable": "vsce package --yarn --out ./dist/extension.vsix",
		"package-extension-preRelease": "vsce package --yarn --out ./dist/extension.vsix --pre-release",
		"dev": "webpack --mode development --watch",
		"dev-drawio-plugins": "webpack --mode development --watch --config ./drawio-custom-plugins/webpack.config.ts",
		"dev-drawio-plugins-web": "webpack-dev-server --hot --config ./drawio-custom-plugins/webpack.config.ts"
	},
	"files": [
		"dist/custom-drawio-plugins/**/*",
		"dist/extension/**/*",
		"package.json",
		"package.nls.json",
		"package.nls.*.json",
		"media/**/*",
		"docs/**/*",
		"drawio/LICENSE",
		"drawio/VERSION",
		"drawio/src/main/webapp/js/**/*",
		"drawio/src/main/webapp/connect/**/*",
		"drawio/src/main/webapp/images/**/*",
		"drawio/src/main/webapp/img/**/*",
		"drawio/src/main/webapp/math4/**/*",
		"drawio/src/main/webapp/mxgraph/**/*",
		"drawio/src/main/webapp/plugins/**/*",
		"drawio/src/main/webapp/resources/**/*",
		"drawio/src/main/webapp/shapes/**/*",
		"drawio/src/main/webapp/stencils/**/*",
		"drawio/src/main/webapp/styles/**/*",
		"drawio/src/main/webapp/templates/**/*",
		"LICENSE.md"
	],
	"devDependencies": {
		"@actions/exec": "^1.0.4",
		"@actions/github": "^2.2.0",
		"@hediet/semver": "^0.2.1",
		"@types/copy-webpack-plugin": "^8.0.1",
		"@types/mithril": "^2.0.4",
		"@types/node": "^22.10.10",
		"@types/vscode": "1.70.0",
		"@types/xml-formatter": "^1.1.0",
		"@vscode/vsce": "^3.2.1",
		"clean-webpack-plugin": "^4.0.0-alpha.0",
		"copy-webpack-plugin": "^9.0.1",
		"css-loader": "^3.4.2",
		"ovsx": "^0.1.0-next.e000fdb",
		"prettier": "^2.3.2",
		"raw-loader": "^4.0.1",
		"style-loader": "^1.1.3",
		"ts-loader": "^9.2.3",
		"ts-node": "^10.1.0",
		"tslint": "^6.1.2",
		"typescript": "^5.7.3",
		"webpack": "^5.44.0",
		"webpack-cli": "^4.7.2",
		"webpack-dev-server": "^3.11.2"
	},
	"dependencies": {
		"@hediet/json-to-dictionary": "^0.2.1",
		"@hediet/std": "0.6.0",
		"@knuddels/mobx-logger": "^1.1.1",
		"buffer": "^6.0.3",
		"js-sha256": "^0.9.0",
		"mithril": "^2.0.4",
		"mobx": "5.15.4",
		"mobx-utils": "5.5.7",
		"path-browserify": "^1.0.1",
		"vsls": "^1.0.3015",
		"xml-formatter": "^2.0.1",
		"xml-parser-xo": "^3.0.0"
	}
}
